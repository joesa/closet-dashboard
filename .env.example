# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only. Used by the Stripe webhook and the
# entitlement gate. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Email + SMS
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs from your Stripe dashboard (Product Catalog → ClosetQuote Pro)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
# Optional: pin the Stripe API version. Leave blank to use the SDK default.
STRIPE_API_VERSION=

# Public site URL — used as Stripe success/cancel return URL.
# In Vercel set this to your production domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Widget API origin (embed data-api-url). Defaults to NEXT_PUBLIC_SITE_URL or closetquotes.com.
NEXT_PUBLIC_APP_URL=
# CDN URL for widget.js (embed script src).
NEXT_PUBLIC_WIDGET_CDN_URL=https://closet-widget.vercel.app/widget.js
# Must match custom-closets-websites ADMIN_BYPASS_SECRET for admin "Review" links.
ADMIN_BYPASS_SECRET=
# (Tenant sites use each tenant's own custom domain from the `domains` table.
# Admin "Review" links open https://<that-domain>. Dev `.localhost` fixtures are
# only previewable when running the sites app locally.)

# Google Gemini — powers the AI site/sitemap generation routes (/api/ai/*).
GEMINI_API_KEY=

# OpenAI — powers bespoke image generation (gpt-image-1) in /api/ai/generate-images.
# Renders the hero + product images that get uploaded to the 'site-assets'
# Supabase Storage bucket. Server-only; never expose to the browser.
OPENAI_API_KEY=

# Demo account anti-abuse. The demo contractor id is the tenant whose widget is
# embedded on marketing pages; calculate/send-lead gate it to allowed origins.
DEMO_CONTRACTOR_ID=
NEXT_PUBLIC_DEMO_CONTRACTOR_ID=
# Comma-separated origins allowed to embed the demo widget.
DEMO_ALLOWED_ORIGINS=
NEXT_PUBLIC_DEMO_ALLOWED_ORIGINS=

# Shared secret guarding the demo-reset cron route (/api/cron/reset-demo).
# Vercel Cron sends this as a Bearer token.
CRON_SECRET=

# Scraper trigger (admin "Run scraper" action).
# In production set the Apify (or other) Actor run webhook URL + token.
SCRAPER_TRIGGER_WEBHOOK_URL=
SCRAPER_TRIGGER_WEBHOOK_TOKEN=
# Local-dev fallback: when not on Vercel, the action shells out to the scraper.
SCRAPER_LOCAL_DIR=../closet-scraper
SCRAPER_LOCAL_RUN_COMMAND=npm run start:dev

# Instantly automation (scraper webhook receiver)
# Use the same value as closet-scraper WEBHOOK_AUTH_TOKEN.
INSTANTLY_RECEIVER_AUTH_TOKEN=
# Shared bearer token for scraper->dashboard control-plane APIs.
# Use the same value as SCRAPER_CONTROL_PLANE_TOKEN in closet-scraper.
SCRAPER_CONTROL_PLANE_TOKEN=
INSTANTLY_MIN_LEADS_PER_BATCH=1
INSTANTLY_WARMUP_MODE=true
INSTANTLY_AUTO_START=false

# Instantly API settings
INSTANTLY_API_KEY=
INSTANTLY_API_BASE_URL=https://api.instantly.ai/api/v2
INSTANTLY_API_AUTH_HEADER=Authorization
INSTANTLY_API_AUTH_PREFIX=Bearer
INSTANTLY_CAMPAIGNS_PATH=/campaigns
INSTANTLY_CAMPAIGN_SEARCH_QUERY_PARAM=search
INSTANTLY_UPDATE_CAMPAIGN_PATH=/campaigns/{campaignId}
INSTANTLY_IMPORT_LEADS_PATH=/leads/add
INSTANTLY_START_CAMPAIGN_PATH=/campaigns/{campaignId}/activate
